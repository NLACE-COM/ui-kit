{
  "alias": {
    "$type": "other",
    "$description": "Aliases semanticos late-bound: apuntan a la var publica con var(), no al hex, para respetar overrides/theming en runtime.",
    "fg-1":      { "$value": "var(--nl-text)" },
    "fg-2":      { "$value": "var(--nl-700)" },
    "fg-3":      { "$value": "var(--nl-500)" },
    "fg-4":      { "$value": "var(--nl-400)" },
    "bg-1":      { "$value": "var(--nl-bg)" },
    "bg-2":      { "$value": "var(--nl-white)" },
    "line-soft": { "$value": "var(--nl-border-soft)" },
    "line-ui":   { "$value": "var(--nl-border-ui)" }
  }
}
