{
  "name": "@nlace/ui-kit",
  "publishConfig": {
    "access": "public"
  },
  "version": "2.3.0",
  "description": "NLACE Design System — fuente única de tokens (W3C DTCG + Style Dictionary), CSS vars, Tailwind v4/v3, objeto JS/TS y 14 componentes React",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./tokens": "./src/tokens/tokens.css",
    "./tokens-js": {
      "types": "./src/tokens/tokens.d.ts",
      "import": "./src/tokens/tokens.mjs",
      "require": "./src/tokens/tokens.cjs"
    },
    "./tokens.json": "./src/tokens/tokens.json",
    "./tailwind-v4": "./src/tokens/tailwind-v4.css",
    "./preset": "./src/tailwind-preset.js",
    "./fonts": "./src/tokens/fonts.css"
  },
  "files": [
    "dist",
    "src/tokens",
    "src/tailwind-preset.js",
    "skill",
    "src/fonts"
  ],
  "scripts": {
    "tokens:build": "node build/build-tokens.mjs",
    "build": "npm run tokens:build && vite build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nlace",
    "design-system",
    "tailwind",
    "ui-kit"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.1"
  }
}
